{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{",  "close": "}" },
        { "open": "[",  "close": "]" },
        { "open": "(",  "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "'",  "close": "'",  "notIn": ["string", "comment"] },
        { "open": "/*", "close": " */"}
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*//\\s*#?region\\b",
            "end":   "^\\s*//\\s*#?endregion\\b"
        }
    },
    "indentationRules": {
        "increaseIndentPattern": "^.*(:|\\{[^}\"']*|\\([^)\"']*)$",
        "decreaseIndentPattern": "^\\s*(elif|else|catch|finally)\\b.*:|^(.*\\*/)?\\s*[\\}\\]].*$"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*(?:Fonction\\.create|if|elif|else|for|while|loop|match|impl|class|struct|try|catch|finally).*?:\\s*$",
            "action": {
                "indent": "indent"
            }
        }
    ],
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
